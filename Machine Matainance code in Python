import datetime

FILENAME = "maintenance_log.txt"


def add_record():
    machine = input("Enter machine name: ")
    last_service = input("Enter last service date (YYYY-MM-DD): ")
    interval = int(input("Enter service interval (in days): "))

    last_date = datetime.datetime.strptime(last_service, "%Y-%m-%d").date()
    next_service = last_date + datetime.timedelta(days=interval)

    with open(FILENAME, "a") as file:
        file.write(f"{machine},{last_service},{interval},{next_service}\n")

    print(f"\nNext service date for {machine}: {next_service}\n")


def view_records():
    try:
        with open(FILENAME, "r") as file:
            records = file.readlines()

            if not records:
                print("\nNo records found.\n")
                return

            print("\n=== All Maintenance Records ===\n")
            for record in records:
                machine, last, interval, next_service = record.strip().split(",")

                print(f"Machine Name      : {machine}")
                print(f"Last Service Date : {last}")
                print(f"Interval (days)   : {interval}")
                print(f"Next Service Date : {next_service}")
                print("-" * 35)

    except FileNotFoundError:
        print("\nNo records found.\n")


def check_due_services():
    today = datetime.date.today()

    try:
        with open(FILENAME, "r") as file:
            records = file.readlines()
            print("\n=== Maintenance Status Report ===\n")

            for record in records:
                machine, last, interval, next_service = record.strip().split(",")
                next_date = datetime.datetime.strptime(next_service, "%Y-%m-%d").date()
                days_overdue = (today - next_date).days

                if days_overdue == 0:
                    print(f"{machine} - Service DUE TODAY")
                elif days_overdue > 0:
                    print(f"{machine} - OVERDUE by {days_overdue} days")
                else:
                    print(f"{machine} - On schedule")

    except FileNotFoundError:
        pass


def menu():
    while True:
        print("\n===== Machine Maintenance Log System =====")
        check_due_services()

        print("\n1. Add Maintenance Record")
        print("2. View All Records")
        print("3. Exit")

        choice = input("\nEnter your choice: ")

        if choice == "1":
            add_record()
        elif choice == "2":
            view_records()
        elif choice == "3":
            print("Exiting program...")
            break
        else:
            print("Invalid choice. Try again.")


menu()
