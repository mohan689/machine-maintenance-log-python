from datetime import datetime, timedelta
import smtplib
from email.message import EmailMessage
import os

FILE_NAME = "maintenance_log.txt"

# ========== EMAIL ALERT FUNCTION ==========
def send_email_alert(machine, days_overdue):
    sender_email = "mohankrishnachundru012@gmail.com"
    app_password = "atmycyyfrqwwdide"   # ← NO SPACES
    receiver_email = "mohankrishnachundru012@gmail.com"

    msg = EmailMessage()
    msg.set_content(
        f"⚠️ MAINTENANCE ALERT!\n\n"
        f"Machine: {machine}\n"
        f"Service is OVERDUE by {days_overdue} days.\n"
        f"Please perform maintenance immediately."
    )
    msg['Subject'] = f"Maintenance Alert: {machine} OVERDUE"
    msg['From'] = sender_email
    msg['To'] = receiver_email

    try:
        print("Connecting to Gmail...")
        with smtplib.SMTP_SSL('smtp.gmail.com', 465) as smtp:
            smtp.login(sender_email, app_password)
            print("Login success")
            smtp.send_message(msg)
        print("📧 Email alert sent successfully!")
    except Exception as e:
        print("❌ Email failed:", e)

# ========== ADD RECORD ==========
def add_record():
    machine = input("Enter machine name: ")
    last_service = input("Enter last service date (YYYY-MM-DD): ")
    interval = int(input("Enter service interval (in days): "))

    next_service = datetime.strptime(last_service, "%Y-%m-%d") + timedelta(days=interval)

    with open(FILE_NAME, "a") as f:
        f.write(f"{machine},{last_service},{interval},{next_service.date()}\n")

    print("✅ Record added successfully!\n")

# ========== VIEW RECORDS ==========
def view_records():
    if not os.path.exists(FILE_NAME):
        print("No records found.\n")
        return

    today = datetime.today().date()

    with open(FILE_NAME, "r") as f:
        records = f.readlines()

    for record in records:
        machine, last_service, interval, next_service = record.strip().split(",")
        next_service_date = datetime.strptime(next_service, "%Y-%m-%d").date()

        print(f"\nMachine: {machine}")
        print(f"Last Service: {last_service}")
        print(f"Next Service: {next_service_date}")

        if today > next_service_date:
            days_overdue = (today - next_service_date).days
            print(f"🔴 OVERDUE by {days_overdue} days")
            send_email_alert(machine, days_overdue)
        else:
            days_left = (next_service_date - today).days
            print(f"🟢 {days_left} days remaining")

# ========== MENU ==========
def menu():
    while True:
        print("\n===== Machine Maintenance Log System =====")
        print("1. Add Maintenance Record")
        print("2. View All Records")
        print("3. Exit")

        choice = input("Enter your choice: ")

        if choice == '1':
            add_record()
        elif choice == '2':
            view_records()
        elif choice == '3':
            print("Exiting program.")
            break
        else:
            print("Invalid choice. Try again.")

# ========== RUN ==========
menu()
